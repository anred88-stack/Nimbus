#!/usr/bin/env sh
# Validate commit messages:
#   1. Conventional Commits: type(scope?): subject
#      Allowed types: feat, fix, chore, docs, refactor, test, ci, build, perf, style, revert
#   2. DCO sign-off: a "Signed-off-by: Name <email>" trailer is required.
#      Run `git commit -s` (or configure an alias) to add it automatically.

msg_file="$1"
# Skip merge, squash, fixup, and revert commits (git generates them itself).
first_line=$(head -n 1 "$msg_file")
case "$first_line" in
  "Merge "*|"Revert "*|"fixup! "*|"squash! "*|"amend! "*) exit 0 ;;
esac

# --- Conventional Commits ------------------------------------------------
cc_re='^(feat|fix|chore|docs|refactor|test|ci|build|perf|style|revert)(\([a-z0-9_.,/-]+\))?!?: .+'
if ! printf '%s' "$first_line" | grep -Eq "$cc_re"; then
  printf '\n\033[31m✗ Commit subject does not follow Conventional Commits.\033[0m\n'
  printf '  Expected: <type>(<scope>)?: <subject>\n'
  printf '  Types:    feat, fix, chore, docs, refactor, test, ci, build, perf, style, revert\n'
  printf '  Got:      %s\n\n' "$first_line"
  exit 1
fi

# --- DCO sign-off --------------------------------------------------------
if ! grep -Eq '^Signed-off-by: .+ <.+@.+>$' "$msg_file"; then
  printf '\n\033[31m✗ Missing DCO sign-off.\033[0m\n'
  printf '  Add one by committing with:  git commit -s\n'
  printf '  See CONTRIBUTING.md for details.\n\n'
  exit 1
fi

exit 0
