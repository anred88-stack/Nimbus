{
  "name": "nimbus",
  "version": "0.0.0",
  "private": true,
  "description": "Browser-based simulator for catastrophic events on a 3D Earth: impacts, explosions, earthquakes, volcanoes, tsunamis. Numbers come from peer-reviewed papers.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "simulate": "tsx scripts/simulate-impact.ts",
    "sensitivity": "tsx scripts/sensitivity.ts",
    "audit:phase10": "tsx scripts/audit_phase10.ts",
    "lighthouse": "lhci autorun",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource/inter": "^5.1.0",
    "@fontsource/jetbrains-mono": "^5.1.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-router": "^1.95.0",
    "cesium": "^1.140.0",
    "comlink": "^4.4.2",
    "geotiff": "^3.0.5",
    "i18next": "^24.2.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.4.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.17.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.50.0",
    "@storybook/addon-a11y": "^8.6",
    "@storybook/react": "^8.4.0",
    "@storybook/react-vite": "^8.4.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@vitest/ui": "^3.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "husky": "^9.1.0",
    "jsdom": "^25.0.0",
    "lint-staged": "^15.3.0",
    "playwright": "^1.50.0",
    "prettier": "^3.4.0",
    "storybook": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.0",
    "vite-plugin-cesium": "^1.2.23",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
